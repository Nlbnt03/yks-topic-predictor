{
  "name": "yks-tahmincim",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":    "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create":  "wrangler d1 create yks-tahmincim-db",
    "db:migrate:local":  "wrangler d1 execute yks-tahmincim-db --local --file=migrations/0001_seed.sql",
    "db:migrate:remote": "wrangler d1 execute yks-tahmincim-db --remote --file=migrations/0001_seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.0.0"
  }
}
